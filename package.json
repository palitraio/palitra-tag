{
  "name": "palitra-tag",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Client-side browser script that collects events for the Palitra platform.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint -c .oxlintrc.json src tests build.mjs",
    "format": "oxfmt src tests build.mjs",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "esbuild": "0.24.0",
    "happy-dom": "15.11.0",
    "oxfmt": "0.1.0",
    "oxlint": "0.13.0",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
