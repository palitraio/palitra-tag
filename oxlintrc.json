{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn",
    "style": "off"
  },
  "plugins": ["typescript", "import", "unicorn"],
  "rules": {
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.ts"],
      "rules": {
        "no-empty-pattern": "off"
      }
    }
  ]
}
